# Supabase (récupérer depuis dashboard.supabase.com > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre-clé-anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre-clé-service...

# WhatsApp Cloud API (récupérer depuis developers.facebook.com)
WHATSAPP_PHONE_ID=votre-phone-id
